# PayFlow MCP modes:
#   auto      - prefer live FastMCP if reachable, else in-project tools (default)
#   embedded  - always use in-project tools (best for Vercel / public demos)
#   http      - require live FastMCP at MCP_SERVER_URL
PAYFLOW_MCP_MODE=auto

# Live FastMCP server (optional - used when mode=auto|http and server is up)
MCP_SERVER_URL=http://127.0.0.1:8000/mcp
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Optional: force live FastMCP only (same as PAYFLOW_MCP_MODE=http)
# PAYFLOW_REQUIRE_LIVE_MCP=1

# ---------------------------------------------------------------------------
# Migrate / Workflow - prod env shape (DEMO_MODE=live only; site runs mockup)
# ---------------------------------------------------------------------------

# MIGRATE_DEMO_MODE is fixed in code as "mockup" today.
# When a live adapter is wired, set:
# MIGRATE_DATABASE_URL=postgres://migrate_user:SECRET@db.example:5432/saas_ops
# (tenant isolation: schema-per-tenant; ETL entrypoint: mcp-server/migrate_pipeline.py)

# WORKFLOW demo mode is fixed in code as "mockup" today.
# When a live adapter is wired, set:
# WORKFLOW_CHECKPOINT_URL=postgres://workflow_user:SECRET@db.example:5432/workflow_ckpt
# (interrupt threshold / approval timeout: see lib/workflow/config.ts)
