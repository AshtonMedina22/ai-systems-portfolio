# PayFlow FastMCP server (Streamable HTTP)
MCP_SERVER_URL=http://127.0.0.1:8000/mcp
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Set to 1 only if you want the Next.js agent to use local TS tools when MCP is down.
# Fallback events are labeled local:fallback_tools (not live MCP).
PAYFLOW_ALLOW_LOCAL_FALLBACK=0
